# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/audio_analysis
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_PREFETCH_COUNT=1

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-files
MINIO_SECURE=false

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# You can use a direct OpenAI key:
# OPENAI_API_KEY=sk-...
# OR use an AI orchestration provider:
AI_PROVIDER_ORCHESTRATION_API_KEY=your-orchestration-key
AI_PROVIDER_ORCHESTRATION_API_URL=https://tme.qubefini.com/ai/api/v1
OPENAI_STT_MODEL=whisper-1
OPENAI_STT_TEMPERATURE=0.0
OPENAI_STT_TIMEOUT_SECONDS=300
OPENAI_REPAIR_MODEL=gpt-4o
OPENAI_REPAIR_TEMPERATURE=0.0
OPENAI_REPAIR_TIMEOUT_SECONDS=120
OPENAI_ANALYSIS_MODEL=gpt-4o
OPENAI_ANALYSIS_TEMPERATURE=0.0
OPENAI_ANALYSIS_TIMEOUT_SECONDS=120

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
APP_CORS_ORIGINS=["*"]

# ─── Watcher ─────────────────────────────────────────────────────────────────
WATCHER_AUDIO_DIR=/audio_files
WATCHER_POLL_INTERVAL_SECONDS=5
